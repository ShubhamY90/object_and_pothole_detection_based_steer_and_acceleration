# =============================================================================
# autonomous_car — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Python bytecode & caches
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.env/

# -----------------------------------------------------------------------------
# Model weights  (large binary files — download on demand)
# -----------------------------------------------------------------------------
# YOLOv8 weights
*.pt
*.pth
*.onnx
*.engine
*.tflite
*.torchscript

# MiDaS / torch hub cached models
# (stored in ~/.cache/torch by default, but guard local copies too)
weights/
checkpoints/

# Fast-SCNN local cache
.cache/

# -----------------------------------------------------------------------------
# Dataset frames  (KITTI images — large, re-downloadable)
# -----------------------------------------------------------------------------
data/

# -----------------------------------------------------------------------------
# Output videos & annotated results
# -----------------------------------------------------------------------------
*.mp4
*.avi
*.mov
*.mkv
output/
outputs/
results/

# -----------------------------------------------------------------------------
# macOS system files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Icon?

# -----------------------------------------------------------------------------
# IDE / editor configs
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Jupyter notebooks (checkpoints & output cells)
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# -----------------------------------------------------------------------------
# Distribution / packaging artefacts
# -----------------------------------------------------------------------------
build/
dist/
*.egg-info/
*.egg
MANIFEST
.eggs/

# -----------------------------------------------------------------------------
# Testing & coverage
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
nosetests.xml
coverage.xml

# -----------------------------------------------------------------------------
# Environment / secrets
# -----------------------------------------------------------------------------
.env
.env.*
*.secret
secrets.yaml
secrets.json

# -----------------------------------------------------------------------------
# Logs & profiling output
# -----------------------------------------------------------------------------
*.log
*.prof
*.lprof
logs/

# -----------------------------------------------------------------------------
# Misc temp files
# -----------------------------------------------------------------------------
tmp/
temp/
scratch/
*.tmp
*.bak
*.orig
